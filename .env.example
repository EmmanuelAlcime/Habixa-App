API_URL=http://localhost:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Stripe (must match API STRIPE_KEY — pk_test_ for sandbox, pk_live_ for production)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Default location for search (e.g. Nassau, NP)
EXPO_PUBLIC_DEFAULT_LOCATION=Nassau, NP
EXPO_PUBLIC_DEFAULT_CITY=Nassau

# Social auth (optional - buttons disabled until set)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Persona identity verification
EXPO_PUBLIC_PERSONA_TEMPLATE_ID=itmpl_xxx
EXPO_PUBLIC_PERSONA_ENVIRONMENT=sandbox
